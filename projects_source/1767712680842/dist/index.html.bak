<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Smile Dental Care</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700&family=Roboto:wght@400;500;700&display=swap" rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        :root {
            --color-primary: #3C8D7D;
            --color-secondary: #7DBCCB;
            --color-accent: #F0A3A7;
            --color-background: #F8F8F8;
            --color-text: #1A1A1A;
            --color-buttonBackground: #3C8D7D;
            --color-buttonText: #FFFFFF;
        }
        html {
            scroll-behavior: smooth;
        }
    </style>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        primary: 'var(--color-primary)',
                        secondary: 'var(--color-secondary)',
                        accent: 'var(--color-accent)',
                        background: 'var(--color-background)',
                        text: 'var(--color-text)',
                        buttonBackground: 'var(--color-buttonBackground)',
                        buttonText: 'var(--color-buttonText)',
                    },
                    fontFamily: {
                        heading: ['Montserrat', 'sans-serif'],
                        body: ['Roboto', 'sans-serif'],
                    },
                }
            }
        }
    </script>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;700&family=Roboto:wght@300;400;600&display=swap" rel="stylesheet">
<link href="./style.css" rel="stylesheet">
<link rel="icon" type="image/png" href="./logo.png" />
</head>
<body class="font-body text-text bg-background antialiased">
    <div id="root" class="overflow-x-hidden">
        <!-- Header Section -->
        <header data-section="header" class="bg-background shadow-sm sticky top-0 z-50">
            <nav class="container mx-auto px-4 py-4 flex justify-between items-center">
                <a href="#" class="flex items-center space-x-2">
                    <img src="./logo.png" alt="Smile Dental Care Logo" class="h-10">
                    <span class="font-heading text-2xl font-bold text-primary">Smile Dental Care</span>
                </a>
                <div class="hidden md:flex space-x-8">
                    <a href="#hero" class="font-body text-lg text-text hover:text-primary transition-colors duration-300">Home</a>
                    <a href="#services" class="font-body text-lg text-text hover:text-primary transition-colors duration-300">Services</a>
                    <a href="#about" class="font-body text-lg text-text hover:text-primary transition-colors duration-300">About Us</a>
                    <a href="#reviews" class="font-body text-lg text-text hover:text-primary transition-colors duration-300">Reviews</a>
                    <a href="#contact" class="font-body text-lg text-text hover:text-primary transition-colors duration-300">Contact</a>
                </div>
                <button id="mobile-menu-button" class="md:hidden text-text focus:outline-none">
                    <i class="fa-solid fa-bars text-2xl"></i>
                </button>
            </nav>
            <!-- Mobile Menu -->
            <div id="mobile-menu" class="hidden md:hidden bg-background absolute top-full left-0 w-full shadow-lg pb-4">
                <nav class="flex flex-col items-center space-y-4">
                    <a href="#hero" class="font-body text-lg text-text hover:text-primary transition-colors duration-300 w-full text-center py-2">Home</a>
                    <a href="#services" class="font-body text-lg text-text hover:text-primary transition-colors duration-300 w-full text-center py-2">Services</a>
                    <a href="#about" class="font-body text-lg text-text hover:text-primary transition-colors duration-300 w-full text-center py-2">About Us</a>
                    <a href="#reviews" class="font-body text-lg text-text hover:text-primary transition-colors duration-300 w-full text-center py-2">Reviews</a>
                    <a href="#contact" class="font-body text-lg text-text hover:text-primary transition-colors duration-300 w-full text-center py-2">Contact</a>
                </nav>
            </div>
        </header>

        <!-- Hero Section -->
        <section data-section="hero" id="hero" class="relative bg-background py-16 md:py-24 overflow-hidden">
            <div class="container mx-auto px-4 grid md:grid-cols-2 gap-12 items-center">
                <div class="text-center md:text-left">
                    <h1 class="font-heading text-4xl md:text-5xl lg:text-6xl font-bold text-text leading-tight mb-6">
                        Your Brightest Smile Starts Here at <span class="text-primary">Smile Dental Care</span>
                    </h1>
                    <p class="font-body text-lg md:text-xl text-text mb-8 max-w-xl mx-auto md:mx-0">
                        Experience exceptional, state-of-the-art dental care with advanced low-level laser technology for smooth and remarkably painless procedures.
                    </p>
                    <div class="flex flex-col sm:flex-row justify-center md:justify-start space-y-4 sm:space-y-0 sm:space-x-4">
                        <a href="#contact" class="bg-buttonBackground text-buttonText font-heading font-semibold py-3 px-8 rounded-full shadow-lg hover:bg-primary/90 transition-all duration-300 text-lg">
                            Book an Appointment
                        </a>
                        <a href="#services" class="bg-transparent border-2 border-primary text-primary font-heading font-semibold py-3 px-8 rounded-full hover:bg-primary hover:text-buttonText transition-all duration-300 text-lg">
                            Our Services
                        </a>
                    </div>
                </div>
                <div class="relative h-96 md:h-[500px] lg:h-[600px] rounded-xl shadow-2xl overflow-hidden">
                    <img src="https://images.unsplash.com/photo-1580821810660-5486b8e980a6?crop=entropy&cs=tinysrgb&fit=max&fm=jpg&ixid=M3w0NTEyODB8MHwxfHJhbmRvbXx8fHx8fHx8fDE3Njc3MTI3MDR8&ixlib=rb-4.1.0&q=80&w=1080" alt="Dentist smiling with patient" class="absolute inset-0 w-full h-full object-cover">
                    <div class="absolute inset-0 bg-black/20"></div>
                </div>
            </div>
        </section>

        <!-- About Us Section -->
        <section data-section="about" id="about" class="bg-secondary/10 py-16 md:py-24">
            <div class="container mx-auto px-4 grid md:grid-cols-2 gap-12 items-center">
                <div class="relative h-96 md:h-[500px] rounded-xl shadow-2xl overflow-hidden order-2 md:order-1">
                    <img src="https://images.unsplash.com/photo-1584434081454-2a898b8e33d5?crop=entropy&cs=tinysrgb&fit=max&fm=jpg&ixid=M3w0NTEyODB8MHwxfHJhbmRvbXx8fHx8fHx8fDE3Njc3MTI3MDR8&ixlib=rb-4.1.0&q=80&w=1080" alt="Modern dental office interior" class="absolute inset-0 w-full h-full object-cover">
                    <div class="absolute inset-0 bg-black/20"></div>
                </div>
                <div class="text-center md:text-left order-1 md:order-2">
                    <h2 class="font-heading text-3xl md:text-4xl font-bold text-text mb-6">
                        A Patient-Focused Approach to Dental Care
                    </h2>
                    <p class="font-body text-lg text-text mb-4">
                        At Smile Dental Care, we combine advanced technology with a deeply caring approach. Our highly skilled doctor meticulously explains every step of your treatment, ensuring you're comfortable and fully informed.
                    </p>
                    <p class="font-body text-lg text-text mb-6">
                        Our friendly and supportive staff are dedicated to creating a clean, peaceful, and welcoming atmosphere where your comfort is our top priority. We believe in delivering not just smiles, but confidence.
                    </p>
                    <ul class="list-none space-y-3 text-lg text-text mb-8">
                        <li class="flex items-center justify-center md:justify-start">
                            <i class="fa-solid fa-check-circle text-primary mr-3"></i>
                            <span class="font-body">Advanced Low-Level Laser Technology</span>
                        </li>
                        <li class="flex items-center justify-center md:justify-start">
                            <i class="fa-solid fa-check-circle text-primary mr-3"></i>
                            <span class="font-body">Highly Skilled & Caring Doctor</span>
                        </li>
                        <li class="flex items-center justify-center md:justify-start">
                            <i class="fa-solid fa-check-circle text-primary mr-3"></i>
                            <span class="font-body">Detailed Patient Education</span>
                        </li>
                    </ul>
                    <a href="#contact" class="bg-primary text-buttonText font-heading font-semibold py-3 px-8 rounded-full shadow-lg hover:bg-primary/90 transition-all duration-300 text-lg">
                        Learn More
                    </a>
                </div>
            </div>
        </section>

        <!-- Services Section -->
        <section data-section="services" id="services" class="bg-background py-16 md:py-24">
            <div class="container mx-auto px-4 text-center">
                <h2 class="font-heading text-3xl md:text-4xl font-bold text-text mb-4">
                    Our Advanced Dental Services
                </h2>
                <p class="font-body text-lg text-text max-w-2xl mx-auto mb-12">
                    Utilizing cutting-edge technology and a gentle touch, we offer a comprehensive range of dental services designed for your optimal oral health and comfort.
                </p>
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                    <!-- Service 1 -->
                    <div class="bg-white p-8 rounded-xl shadow-lg hover:shadow-xl transition-shadow duration-300 border-t-4 border-primary">
                        <i class="fa-solid fa-tooth text-5xl text-primary mb-6"></i>
                        <h3 class="font-heading text-xl font-semibold text-text mb-4">Painless Laser Dentistry</h3>
                        <p class="font-body text-text">
                            Experience comfortable procedures with our advanced low-level laser technology, minimizing discomfort and recovery time.
                        </p>
                    </div>
                    <!-- Service 2 -->
                    <div class="bg-white p-8 rounded-xl shadow-lg hover:shadow-xl transition-shadow duration-300 border-t-4 border-secondary">
                        <i class="fa-solid fa-hand-holding-medical text-5xl text-secondary mb-6"></i>
                        <h3 class="font-heading text-xl font-semibold text-text mb-4">Comprehensive Check-ups</h3>
                        <p class="font-body text-text">
                            Regular examinations and cleanings to maintain your oral hygiene and detect issues early.
                        </p>
                    </div>
                    <!-- Service 3 -->
                    <div class="bg-white p-8 rounded-xl shadow-lg hover:shadow-xl transition-shadow duration-300 border-t-4 border-accent">
                        <i class="fa-solid fa-star text-5xl text-accent mb-6"></i>
                        <h3 class="font-heading text-xl font-semibold text-text mb-4">Cosmetic Dentistry</h3>
                        <p class="font-body text-text">
                            Achieve your dream smile with our range of cosmetic treatments, including whitening and veneers.
                        </p>
                    </div>
                    <!-- Service 4 -->
                    <div class="bg-white p-8 rounded-xl shadow-lg hover:shadow-xl transition-shadow duration-300 border-t-4 border-primary">
                        <i class="fa-solid fa-fill-drip text-5xl text-primary mb-6"></i>
                        <h3 class="font-heading text-xl font-semibold text-text mb-4">Restorative Procedures</h3>
                        <p class="font-body text-text">
                            From fillings to crowns, we restore the function and aesthetics of your teeth with precision.
                        </p>
                    </div>
                    <!-- Service 5 -->
                    <div class="bg-white p-8 rounded-xl shadow-lg hover:shadow-xl transition-shadow duration-300 border-t-4 border-secondary">
                        <i class="fa-solid fa-x-ray text-5xl text-secondary mb-6"></i>
                        <h3 class="font-heading text-xl font-semibold text-text mb-4">Digital X-rays</h3>
                        <p class="font-body text-text">
                            Advanced diagnostic imaging for accurate and safe assessment of your dental health.
                        </p>
                    </div>
                    <!-- Service 6 -->
                    <div class="bg-white p-8 rounded-xl shadow-lg hover:shadow-xl transition-shadow duration-300 border-t-4 border-accent">
                        <i class="fa-solid fa-child-reaching text-5xl text-accent mb-6"></i>
                        <h3 class="font-heading text-xl font-semibold text-text mb-4">Pediatric Dentistry</h3>
                        <p class="font-body text-text">
                            Gentle and friendly dental care for our youngest patients, ensuring a positive experience.
                        </p>
                    </div>
                </div>
            </div>
        </section>

        <!-- Reviews Section -->
        <section data-section="reviews" id="reviews" class="bg-primary/10 py-16 md:py-24">
            <div class="container mx-auto px-4 text-center">
                <h2 class="font-heading text-3xl md:text-4xl font-bold text-text mb-4">
                    What Our Patients Say
                </h2>
                <p class="font-body text-lg text-text max-w-2xl mx-auto mb-12">
                    Hear directly from those who've experienced the Smile Dental Care difference.
                </p>
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                    <!-- Review 1 -->
                    <div class="bg-white p-8 rounded-xl shadow-lg flex flex-col items-center text-center">
                        <div class="text-accent text-2xl mb-4">
                            <i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i>
                        </div>
                        <p class="font-body text-text italic mb-4">
                            "🤩 Exceptional Dental Care & Smooth Procedure! We had a truly excellent dental experience at this clinic recently for a cavity - low level laser. We were initially quite nervous, b..."
                        </p>
