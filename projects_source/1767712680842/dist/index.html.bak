                <div>
                    <h3 class="font-heading text-lg font-semibold text-primary mb-4">Stay Connected</h3>
                    <p class="font-body text-buttonText/80 text-sm mb-4">
                        Subscribe to our newsletter for the latest updates and offers.
                    </p>
                    <form class="flex">
                        <input type="email" placeholder="Your Email" class="p-2 rounded-l-md focus:outline-none focus:ring-2 focus:ring-primary text-text w-full">
