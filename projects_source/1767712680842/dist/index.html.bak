                                style="border:0;"
                                allowfullscreen=""
                                loading="lazy"
                                referrerpolicy="no-referrer-when-downgrade">
                            </iframe>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Footer Section -->
        <footer data-section="footer" class="bg-text text-buttonText py-12">
            <div class="container mx-auto px-4 grid grid-cols-1 md:grid-cols-4 gap-8">
                <!-- Column 1: Business Info -->
                <div>
                    <a href="#" class="flex items-center space-x-2 mb-4">
                        <img src="./logo.png" alt="Smile Dental Care Logo" class="h-8 filter invert">
                        <span class="font-heading text-xl font-bold text-buttonText">Smile Dental Care</span>
                    </a>
                    <p class="font-body text-buttonText/80 text-sm mb-4">
                        Advanced, patient-focused dental care for your brightest smile.
                    </p>
                    <div class="flex space-x-4 text-lg">
                        <a href="#" class="hover:text-primary transition-colors duration-300"><i class="fa-brands fa-facebook"></i></a>
                        <a href="#" class="hover:text-primary transition-colors duration-300"><i class="fa-brands fa-instagram"></i></a>
