                <!-- Column 3: Contact Info -->
                <div>
                    <h3 class="font-heading text-lg font-semibold text-primary mb-4">Contact Us</h3>
                    <ul class="space-y-2 font-body text-buttonText/80">
                        <li><i class="fa-solid fa-map-marker-alt mr-2 text-secondary"></i> Basement, Joshi & Joshi Complex...</li>
                        <li><i class="fa-solid fa-phone mr-2 text-secondary"></i> 097917 65077</li>
                        <li><i class="fa-solid fa-envelope mr-2 text-secondary"></i> info@smiledentalcare.com</li>
                    </ul>
