        </motion.section>

        {/* Selling Points / Services Section */}
        <motion.section
          data-section="services"
          id="services"
          className="py-16 px-6 md:px-12 bg-secondary/10"
          initial="hidden"
          whileInView="visible"
          viewport={{ once: true, amount: 0.3 }}
          variants={sectionVariants}
        >
          <motion.h2 variants={itemVariants} className="text-4xl font-heading font-bold text-primary text-center mb-12">
            Why Choose Surya Dental Care?
          </motion.h2>
          <div className="grid md:grid-cols-2 lg:grid-cols-3 gap-8 max-w-6xl mx-auto">
            {sellingPoints.map((point, index) => (
              <motion.div
                key={index}
                variants={itemVariants}
                className="flex items-start bg-white p-6 rounded-lg shadow-md hover:shadow-xl transition-shadow duration-300"
              >
                <div className="flex-shrink-0 mr-4">
                  {index % 4 === 0 && <CheckCircle className="text-accent h-8 w-8" />}
                  {index % 4 === 1 && <Smile className="text-accent h-8 w-8" />}
                  {index % 4 === 2 && <Shield className="text-accent h-8 w-8" />}
                  {index % 4 === 3 && <CalendarDays className="text-accent h-8 w-8" />}
                </div>
                <p className="text-lg font-body text-text">{point}</p>
              </motion.div>
            ))}
          </div>
        </motion.section>

        {/* Testimonials Section */}
        <motion.section
          data-section="testimonials"
          id="testimonials"
          className="py-16 px-6 md:px-12 bg-background"
          initial="hidden"
          whileInView="visible"
          viewport={{ once: true, amount: 0.3 }}
          variants={sectionVariants}
        >
          <motion.h2 variants={itemVariants} className="text-4xl font-heading font-bold text-primary text-center mb-12">
            What Our Patients Say
          </motion.h2>
          <div className="grid md:grid-cols-2 lg:grid-cols-3 gap-8 max-w-6xl mx-auto">
            {reviews.map((review, index) => (
              <motion.div
                key={index}
                variants={itemVariants}
                className="bg-white p-8 rounded-lg shadow-md border-t-4 border-accent relative overflow-hidden"
              >
                <Quote className="absolute top-4 left-4 text-accent opacity-20 h-16 w-16 -z-0" />
                <p className="text-lg font-body text-text italic relative z-10 mb-4">"{review}"</p>
                <p className="text-right font-semibold text-primary relative z-10">- Satisfied Patient</p>
              </motion.div>
            ))}
          </div>
        </motion.section>

        {/* Contact Section */}
        <motion.section
          data-section="contact"
          id="contact"
          className="py-16 px-6 md:px-12 bg-primary/10"
          initial="hidden"
          whileInView="visible"
          viewport={{ once: true, amount: 0.3 }}
          variants={sectionVariants}
        >
          <motion.h2 variants={itemVariants} className="text-4xl font-heading font-bold text-primary text-center mb-12">
            Contact Us
          </motion.h2>
          <div className="grid md:grid-cols-2 gap-12 max-w-5xl mx-auto">
            <motion.div variants={itemVariants} className="bg-white p-8 rounded-lg shadow-md">
              <h3 className="text-2xl font-heading font-semibold text-primary mb-6">Get in Touch</h3>
              <div className="space-y-4 text-lg font-body text-text">
                <p className="flex items-start">
                  <MapPin className="text-accent mr-3 mt-1 flex-shrink-0" />
                  <span>{contactDetails.address}</span>
                </p>
                <p className="flex items-center">
                  <Phone className="text-accent mr-3" />
                  <a href={`tel:${contactDetails.phone}`} className="hover:underline">{contactDetails.phone}</a>
                </p>
                <p className="flex items-center">
                  <Globe className="text-accent mr-3" />
                  <a href={contactDetails.website} target="_blank" rel="noopener noreferrer" className="hover:underline">{contactDetails.website}</a>
                </p>
              </div>
            </motion.div>
            <motion.div variants={itemVariants} className="bg-white p-8 rounded-lg shadow-md">
              <h3 className="text-2xl font-heading font-semibold text-primary mb-6">Opening Hours</h3>
              <ul className="space-y-2 text-lg font-body text-text">
                {Object.entries(openingHours).map(([day, hours]) => (
                  <li key={day} className="flex justify-between items-center">
                    <span className="font-semibold">{day}:</span>
                    <span>{hours}</span>
                  </li>
                ))}
              </ul>
            </motion.div>
          </div>
        </motion.section>
      </main>

      {/* Footer */}
      <footer data-section="footer" className="bg-primary text-buttonText py-12 px-6 md:px-12 font-body">
        <div className="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-3 lg:grid-cols-4 gap-8">
          {/* Column 1: Logo/Business Name & Summary */}
          <div className="space-y-4">
            {logoUrl ? (
              <img src={logoUrl} alt={`${businessName} Logo`} className="h-12 w-auto mb-2" />
            ) : (
              <h3 className="text-3xl font-heading font-bold mb-2">{businessName}</h3>
            )}
            <p className="text-buttonText/80 text-sm">
              {businessSummary.split('. ')[0]}. Experience compassionate and professional dental care.
            </p>
          </div>

          {/* Column 2: Quick Links */}
          <div>
            <h4 className="text-xl font-heading font-semibold mb-4">Quick Links</h4>
            <ul className="space-y-2">
              {navLinks.map((link) => (
                <li key={link.name}>
                  <a href={link.href} className="hover:text-accent transition-colors duration-300">
                    {link.name}
