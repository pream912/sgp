              ))}
            </ul>
          </div>

          {/* Column 3: Contact Info */}
          <div>
            <h4 className="text-xl font-heading font-semibold mb-4">Contact Us</h4>
            <ul className="space-y-2">
              <li className="flex items-start">
                <MapPin className="h-5 w-5 mr-2 mt-1 flex-shrink-0" />
                <span>{contactDetails.address}</span>
              </li>
              <li className="flex items-center">
                <Phone className="h-5 w-5 mr-2" />
                <a href={`tel:${contactDetails.phone}`} className="hover:underline">{contactDetails.phone}</a>
              </li>
              <li className="flex items-center">
                <Globe className="h-5 w-5 mr-2" />
                <a href={contactDetails.website} target="_blank" rel="noopener noreferrer" className="hover:underline">Website</a>
              </li>
            </ul>
          </div>

          {/* Column 4: Opening Hours (if not already in Contact section) */}
          <div className="hidden lg:block"> {/* Only show if not already prominently displayed */}
            <h4 className="text-xl font-heading font-semibold mb-4">Hours</h4>
            <ul className="space-y-2">
              {Object.entries(openingHours).map(([day, hours]) => (
                <li key={day} className="flex justify-between">
                  <span>{day}:</span>
                  <span>{hours}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>

        <div className="border-t border-buttonText/30 mt-8 pt-8 text-center text-sm">
          &copy; {new Date().getFullYear()} {businessName}. All rights reserved.
        </div>
      </footer>
