    "Hi this is Mahalakshmi.First of all, I would like to thank Dr. Senthil Sir & the entire team at Surya Dental Care. I first came here in February 2025 for a teeth cleaning. A few mo..."
  ]
};

const { businessName, colorPalette, imageUrls, logoUrl } = designSystem;
const { businessSummary, sellingPoints, contactDetails, openingHours, reviews } = userContext;

let imageIndex = 0;
const getImageUrl = () => {
  const url = imageUrls[imageIndex % imageUrls.length];
  imageIndex++;
  return url;
};

const App = () => {
  const navLinks = [
    { name: 'Home', href: '#home' },
    { name: 'About Us', href: '#about' },
    { name: 'Services', href: '#services' },
    { name: 'Testimonials', href: '#testimonials' },
    { name: 'Contact', href: '#contact' },
  ];

  const headerVariants = {
    hidden: { y: -100 },
    visible: { y: 0, transition: { type: "spring", stiffness: 120, damping: 14, delay: 0.2 } },
  };

  const heroTextVariants = {
    hidden: { opacity: 0, y: 20 },
    visible: { opacity: 1, y: 0, transition: { duration: 0.8, ease: "easeOut" } },
  };

  const sectionVariants = {
    hidden: { opacity: 0, y: 50 },
    visible: { opacity: 1, y: 0, transition: { duration: 0.6, ease: "easeOut", staggerChildren: 0.1 } },
  };

  const itemVariants = {
    hidden: { opacity: 0, y: 20 },
    visible: { opacity: 1, y: 0 },
  };

  return (
    <div className="min-h-screen bg-background text-text font-body">
      {/* Header */}
      <motion.header
        data-section="header"
        className="fixed top-0 left-0 w-full bg-primary text-buttonText shadow-md z-50 py-4 px-6 md:px-12 flex justify-between items-center"
        initial="hidden"
        animate="visible"
        variants={headerVariants}
      >
        <div className="flex items-center">
          {logoUrl ? (
            <img src={logoUrl} alt={`${businessName} Logo`} className="h-10 w-auto mr-3" />
          ) : (
            <h1 className="text-2xl font-heading font-bold">{businessName}</h1>
          )}
        </div>
        <nav className="hidden md:flex space-x-8">
          {navLinks.map((link) => (
            <a key={link.name} href={link.href} className="text-buttonText hover:text-accent font-heading text-lg transition-colors duration-300">
              {link.name}
            </a>
          ))}
        </nav>
        {/* Mobile menu button (optional, not strictly required by prompt but good practice) */}
        <div className="md:hidden">
          {/* Implement a mobile menu icon/toggle here if needed */}
          <button className="text-buttonText focus:outline-none">
            <svg className="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path strokeLinecap="round" strokeLinejoin="round" strokeWidth="2" d="M4 6h16M4 12h16M4 18h16"></path></svg>
          </button>
        </div>
      </motion.header>

      <main className="pt-20"> {/* Adjust pt- to clear fixed header */}
        {/* Hero Section - Full Background Image */}
        <section
          data-section="hero"
          id="home"
          className="relative flex items-center justify-center min-h-[calc(100vh-80px)] overflow-hidden"
        >
          {/* Background Image */}
          <div className="absolute inset-0">
            <img
              src={getImageUrl()}
              alt="Modern Dental Office"
              className="w-full h-full object-cover object-center"
            />
            {/* Overlay for readability */}
            <div className="absolute inset-0 bg-black opacity-50"></div>
          </div>

          {/* Content Overlay */}
          <motion.div
            initial="hidden"
            animate="visible"
            variants={heroTextVariants}
            className="relative z-10 text-center text-white p-8 md:p-16 max-w-3xl"
          >
            <h1 className="text-5xl md:text-6xl font-heading font-extrabold leading-tight mb-4 text-white">
              {businessName}
            </h1>
            <p className="text-xl md:text-2xl font-body mb-8 text-white">
              {businessSummary.split('. ')[0]}. Experience compassionate and professional dental care.
            </p>
            <motion.button
              whileHover={{ scale: 1.05 }}
              whileTap={{ scale: 0.95 }}
              className="bg-buttonBackground text-buttonText font-heading font-semibold py-3 px-8 rounded-full shadow-lg hover:shadow-xl transition-all duration-300"
            >
              Book An Appointment
            </motion.button>
          </motion.div>
        </section>

        {/* About Section */}
        <motion.section
          data-section="about"
          id="about"
          className="py-16 px-6 md:px-12 bg-background"
          initial="hidden"
          whileInView="visible"
          viewport={{ once: true, amount: 0.3 }}
          variants={sectionVariants}
        >
          <motion.h2 variants={itemVariants} className="text-4xl font-heading font-bold text-primary text-center mb-8">
            About {businessName}
          </motion.h2>
          <motion.p variants={itemVariants} className="max-w-3xl mx-auto text-center text-lg font-body text-text leading-relaxed">
            {businessSummary}
