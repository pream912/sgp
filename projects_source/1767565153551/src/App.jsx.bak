const userContext = {
  "businessSummary": "Surya Dental Care stands out as a patient-centric clinic where genuine care meets exceptional professionalism. Praised for transforming potentially anxious visits into comfortable and positive experiences, the dedicated team ensures clear communication, thorough treatments, and a remarkably reassuring atmosphere for every patient.",
